# Face Attendance System - Environment Variables
# AUTH-T3: JWT secret moved out of source code
# COPY THIS FILE to .env and set your own values before running the backend

# JWT signing secret - CHANGE THIS to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
