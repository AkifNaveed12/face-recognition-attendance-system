# Face Attendance System - Environment Variables Configuration
# COPY THIS FILE to .env and customize the values for your environment.

# 1. Backend Security Configurations
# JWT signing secret (Required for Backend API)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Shared Service API Key (Required for internal service communication between Edge Machine and Backend)
# Both backend and attendance_service must have matching keys.
SERVICE_API_KEY=dev-service-api-key

# 2. Database Configurations
# Path to SQLite database file. Useful for mapping to persistent folders (e.g. Railway volume mounts)
# Default: database/attendance.db
# DATABASE_PATH=/app/database/attendance.db

# 3. Production CORS Configurations
# Comma-separated list of allowed frontend origins (Task Group 3 CORS hardening)
# FRONTEND_URL=https://your-app.vercel.app

# 4. Attendance Webcam Service Configurations (For Edge Machine)
# Target URL of your deployed Backend API
# BACKEND_URL=https://your-backend-api.railway.app
